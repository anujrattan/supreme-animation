{
  "name": "supreme-animation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "cp .htaccess out/.htaccess",
    "start": "next start",
    "lint": "eslint",
    "compress-videos": "node scripts/compress-portfolio-videos.js",
    "install:all": "npm install && cd backend && npm install",
